DPI_NODE_FAUCET_CONNECTOR="iota"

DPI_NODE_WALLET_CONNECTOR="iota"

DPI_NODE_IDENTITY_CONNECTOR="iota"

# Post-#203/next.54: bootstrap-legacy feature flags renamed to "admin-user,wallet"
# (node identity is now always created; the old node-identity/node-admin-user/node-wallet
# names are silently ignored, which skips admin-user creation -> login fails).
DPI_NODE_FEATURES="admin-user,wallet"
